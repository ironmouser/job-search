generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  isCustomCareerPage Boolean   @default(false) @map("is_custom_career_page")
  addedById          String?   @map("added_by_id")
  title            String
  company          String
  location         String?
  salaryRange      String?   @map("salary_range")
  description      String?
  requirements     String?
  url              String    @unique
  source           String?
  status           String    @default("discovered")
  appliedAt        DateTime? @map("applied_at") @db.Timestamptz(6)
  isArchived       Boolean   @default(false) @map("is_archived")
  isViewed         Boolean   @default(false) @map("is_viewed")

  userJobs          UserJob[]
  opportunityScores OpportunityScore[]
  applicationAssets ApplicationAsset[]
  jobFeedbacks      JobFeedback[]

  @@map("jobs")
}

model OpportunityScore {
  id                     String   @id @default(uuid()) @db.Uuid
  jobId                  String   @map("job_id") @db.Uuid
  userId                 String?  @map("user_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  totalScore             Int      @map("total_score")
  compensationScore      Int      @map("compensation_score")
  productFitScore        Int      @map("product_fit_score")
  remoteFlexibilityScore Int      @map("remote_flexibility_score")
  aiMaturityScore        Int      @map("ai_maturity_score")
  leadershipScore        Int      @map("leadership_score")
  growthScore            Int      @map("growth_score")
  cultureScore           Int      @map("culture_score")
  techStackScore         Int      @map("tech_stack_score")
  analysisNotes          String?  @map("analysis_notes")

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalScore(sort: Desc)])
  @@index([jobId])
  @@map("opportunity_scores")
}

model ApplicationAsset {
  id                     String   @id @default(uuid()) @db.Uuid
  jobId                  String   @map("job_id") @db.Uuid
  userId                 String?  @map("user_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tailoredResumeMarkdown String?  @map("tailored_resume_markdown")
  coverLetterMarkdown    String?  @map("cover_letter_markdown")
  networkingMessage      String?  @map("networking_message")
  portfolioRecommendation String? @map("portfolio_recommendation")
  resumeRegensUsed            Int @default(0) @map("resume_regens_used")
  coverLetterRegensUsed       Int @default(0) @map("cover_letter_regens_used")
  networkingMessageRegensUsed Int @default(0) @map("networking_message_regens_used")
  qaGenerationsUsed           Int @default(0) @map("qa_generations_used")

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("application_assets")
}

model JobFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  jobId        String   @unique @map("job_id") @db.Uuid
  userId       String?  @map("user_id")
  feedbackType String   @map("feedback_type") // 'like' or 'dislike'
  reasons      String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_feedback")
}

model SyncLog {
  id           String   @id @default(uuid()) @db.Uuid
  syncType     String   @map("sync_type")
  lastSyncedAt DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@map("sync_logs")
}

model ScraperLog {
  id             String   @id @default(uuid()) @db.Uuid
  scraperName    String   @map("scraper_name")
  targetUrl      String?  @map("target_url")
  status         String   // 'SUCCESS', 'FAILURE', 'PARTIAL'
  resultsCount   Int      @default(0) @map("results_count")
  errorDetails   String?  @map("error_details")
  usedFirecrawl  Boolean  @default(false) @map("used_firecrawl")
  firecrawlSites String[] @default([]) @map("firecrawl_sites")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@map("scraper_logs")
}

// NextAuth Models

enum Role {
  USER
  ADMIN
}

model GlobalSettings {
  id                    String  @id @default("system")
  // Scrapers
  jsearchIsPro          Boolean @default(true) @map("jsearch_is_pro")
  greenhouseIsPro       Boolean @default(true) @map("greenhouse_is_pro")
  leverIsPro            Boolean @default(false) @map("lever_is_pro")
  ashbyIsPro            Boolean @default(false) @map("ashby_is_pro")
  workableIsPro         Boolean @default(true) @map("workable_is_pro")
  smartrecruitersIsPro  Boolean @default(true) @map("smartrecruiters_is_pro")
  breezyIsPro           Boolean @default(true) @map("breezy_is_pro")
  remotiveIsPro         Boolean @default(true) @map("remotive_is_pro")
  weworkremotelyIsPro   Boolean @default(false) @map("weworkremotely_is_pro")
  remotecoIsPro         Boolean @default(false) @map("remoteco_is_pro")
  remoteokIsPro         Boolean @default(false) @map("remoteok_is_pro")
  workingnomadsIsPro    Boolean @default(false) @map("workingnomads_is_pro")
  // Email Sync
  emailsSyncIsPro       Boolean @default(true) @map("emails_sync_is_pro")
  // AI Features
  aiOpportunityScoringIsPro Boolean @default(true) @map("ai_opportunity_scoring_is_pro")
  aiAssetGenerationIsPro    Boolean @default(true) @map("ai_asset_generation_is_pro")
  aiQaHelperIsPro           Boolean @default(true) @map("ai_qa_helper_is_pro")

  @@map("global_settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)

  // Stripe & Subscriptions
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  trialEndsAt            DateTime?
  planTier               String    @default("FREE")
  isOnboarded            Boolean   @default(false) @map("is_onboarded")

  accounts      Account[]
  sessions      Session[]
  
  userPreferences UserPreferences?
  userJobs        UserJob[]
  scores          OpportunityScore[]
  assets          ApplicationAsset[]
  feedbacks       JobFeedback[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  searchKeyword     String?
  searchLocation    String?
  customCareerPages String[] @default([])
  sources           Json?    @default("{}")
  remoteOnly        Boolean  @default(false)
  theme             String   @default("dark")
  aiStrictness      String   @default("Standard")
  coverLetterTone       String?  @default("Confident and strategic") @map("cover_letter_tone")
  networkingMessageTone String?  @default("Confident and strategic") @map("networking_message_tone")
  resumeCustomizationMaxPercentage Int @default(50)
  resumeMarkdown    String?  @db.Text
  profile           String?  @db.Text
  emailAddress      String?
  emailAppPassword  String?
  imapHost          String?  @default("imap.gmail.com")
  imapPort          Int?     @default(993)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserJob {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  jobId      String    @map("job_id") @db.Uuid
  status     String    @default("discovered")
  appliedAt  DateTime? @map("applied_at") @db.Timestamptz(6)
  ipAddress  String?   @map("ip_address")
  isArchived Boolean   @default(false) @map("is_archived")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("user_jobs")
}

model ScrapeCache {
  id        String   @id @default(cuid())
  source    String   
  keyword   String   @default("")
  location  String   @default("")
  rawJobs   Json     @default("[]")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  @@unique([source, keyword, location])
  @@index([expiresAt])
  @@map("scrape_cache")
}
