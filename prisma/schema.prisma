generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  isCustomCareerPage Boolean   @default(false) @map("is_custom_career_page")
  addedById          String?   @map("added_by_id")
  title            String
  company          String
  location         String?
  salaryRange      String?   @map("salary_range")
  description      String?
  requirements     String?
  url              String    @unique
  source           String?
  status           String    @default("discovered")
  appliedAt        DateTime? @map("applied_at") @db.Timestamptz(6)
  isArchived       Boolean   @default(false) @map("is_archived")
  isViewed         Boolean   @default(false) @map("is_viewed")

  userJobs          UserJob[]
  opportunityScores OpportunityScore[]
  applicationAssets ApplicationAsset[]
  jobFeedbacks      JobFeedback[]
  autoApplySessions AutoApplySession[]

  @@map("jobs")
}

model OpportunityScore {
  id                     String   @id @default(uuid()) @db.Uuid
  jobId                  String   @map("job_id") @db.Uuid
  userId                 String?  @map("user_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  totalScore             Int      @map("total_score")
  compensationScore      Int      @map("compensation_score")
  productFitScore        Int      @map("product_fit_score")
  remoteFlexibilityScore Int      @map("remote_flexibility_score")
  aiMaturityScore        Int      @map("ai_maturity_score")
  leadershipScore        Int      @map("leadership_score")
  growthScore            Int      @map("growth_score")
  cultureScore           Int      @map("culture_score")
  techStackScore         Int      @map("tech_stack_score")
  analysisNotes          String?  @map("analysis_notes")

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalScore(sort: Desc)])
  @@index([jobId])
  @@unique([userId, jobId])
  @@map("opportunity_scores")
}

model ApplicationAsset {
  id                     String   @id @default(uuid()) @db.Uuid
  jobId                  String   @map("job_id") @db.Uuid
  userId                 String?  @map("user_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tailoredResumeMarkdown String?  @map("tailored_resume_markdown")
  coverLetterMarkdown    String?  @map("cover_letter_markdown")
  networkingMessage      String?  @map("networking_message")
  portfolioRecommendation String? @map("portfolio_recommendation")
  resumeRegensUsed            Int @default(0) @map("resume_regens_used")
  coverLetterRegensUsed       Int @default(0) @map("cover_letter_regens_used")
  networkingMessageRegensUsed Int @default(0) @map("networking_message_regens_used")
  qaGenerationsUsed           Int @default(0) @map("qa_generations_used")

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@unique([userId, jobId])
  @@map("application_assets")
}

model JobFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  userId       String?  @map("user_id")
  feedbackType String   @map("feedback_type") // 'like' or 'dislike'
  reasons      String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@unique([userId, jobId])
  @@map("job_feedback")
}

model SyncLog {
  id           String   @id @default(uuid()) @db.Uuid
  syncType     String   @map("sync_type")
  lastSyncedAt DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@map("sync_logs")
}

model ScraperLog {
  id             String   @id @default(uuid()) @db.Uuid
  scraperName    String   @map("scraper_name")
  targetUrl      String?  @map("target_url")
  status         String   // 'SUCCESS', 'FAILURE', 'PARTIAL'
  resultsCount   Int      @default(0) @map("results_count")
  errorDetails   String?  @map("error_details")
  usedFirecrawl  Boolean  @default(false) @map("used_firecrawl")
  firecrawlSites String[] @default([]) @map("firecrawl_sites")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@map("scraper_logs")
}

// NextAuth Models

enum Role {
  USER
  ADMIN
}

model GlobalSettings {
  id                    String  @id @default("system")
  // Scrapers

  greenhouseIsPro       Boolean @default(true) @map("greenhouse_is_pro")
  leverIsPro            Boolean @default(false) @map("lever_is_pro")
  ashbyIsPro            Boolean @default(false) @map("ashby_is_pro")
  workableIsPro         Boolean @default(true) @map("workable_is_pro")
  smartrecruitersIsPro  Boolean @default(true) @map("smartrecruiters_is_pro")
  breezyIsPro           Boolean @default(true) @map("breezy_is_pro")
  remotiveIsPro         Boolean @default(true) @map("remotive_is_pro")
  weworkremotelyIsPro   Boolean @default(false) @map("weworkremotely_is_pro")
  remotecoIsPro         Boolean @default(false) @map("remoteco_is_pro")
  remoteokIsPro         Boolean @default(false) @map("remoteok_is_pro")
  workingnomadsIsPro    Boolean @default(false) @map("workingnomads_is_pro")
  remotepocIsPro        Boolean @default(false) @map("remotepoc_is_pro")
  arbeitnowIsPro        Boolean @default(false) @map("arbeitnow_is_pro")
  ycombinatorIsPro      Boolean @default(false) @map("ycombinator_is_pro")
  himalayasIsPro        Boolean @default(true) @map("himalayas_is_pro")
  ottaIsPro             Boolean @default(true) @map("otta_is_pro")
  jobspressoIsPro       Boolean @default(true) @map("jobspresso_is_pro")
  justremoteIsPro       Boolean @default(true) @map("justremote_is_pro")
  // Email Sync
  emailsSyncIsPro       Boolean @default(true) @map("emails_sync_is_pro")
  // AI Features
  aiOpportunityScoringIsPro Boolean @default(true) @map("ai_opportunity_scoring_is_pro")
  aiAssetGenerationIsPro    Boolean @default(true) @map("ai_asset_generation_is_pro")
  aiQaHelperIsPro           Boolean @default(true) @map("ai_qa_helper_is_pro")
  autoApplyIsPro            Boolean @default(true) @map("auto_apply_is_pro")

  @@map("global_settings")

}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)

  // Stripe & Subscriptions
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  trialEndsAt            DateTime?
  planTier               String    @default("FREE")
  isOnboarded            Boolean   @default(false) @map("is_onboarded")

  accounts      Account[]
  sessions      Session[]
  
  userPreferences      UserPreferences?
  userJobs             UserJob[]
  scores               OpportunityScore[]
  assets               ApplicationAsset[]
  feedbacks            JobFeedback[]
  autoApplySessions    AutoApplySession[]
  interventionRequests InterventionRequest[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  searchKeyword     String?
  searchLocation    String?
  customCareerPages String[] @default([])
  sources           Json?    @default("{}")
  remoteOnly        Boolean  @default(false)
  theme             String   @default("light")
  aiStrictness      String   @default("Standard")
  coverLetterTone       String?  @default("Confident and strategic") @map("cover_letter_tone")
  networkingMessageTone String?  @default("Confident and strategic") @map("networking_message_tone")
  resumeCustomizationMaxPercentage Int @default(50)
  resumeMarkdown    String?  @db.Text
  profile           String?  @db.Text
  emailAddress      String?
  emailAppPassword  String?
  imapHost          String?  @default("imap.gmail.com")
  imapPort          Int?     @default(993)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserJob {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  jobId      String    @map("job_id") @db.Uuid
  status     String    @default("discovered")
  appliedAt  DateTime? @map("applied_at") @db.Timestamptz(6)
  ipAddress  String?   @map("ip_address")
  isArchived Boolean   @default(false) @map("is_archived")
  isPrivate Boolean   @default(false) @map("is_private")
  unlockedBySubmission Boolean @default(false) @map("unlocked_by_submission")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("user_jobs")
}

model ScrapeCache {
  id        String   @id @default(cuid())
  source    String   
  keyword   String   @default("")
  location  String   @default("")
  rawJobs   Json     @default("[]")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  @@unique([source, keyword, location])
  @@index([expiresAt])
  @@map("scrape_cache")
}

// ─── Auto Apply Models ──────────────────────────────────────────────────────

model AutoApplySession {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id")
  jobId                String    @map("job_id") @db.Uuid
  status               String    @default("queued")   // AutoApplyStatus enum value
  atsPlatform          String?   @map("ats_platform")  // ATSPlatform enum value
  atsConfidence        Int?      @map("ats_confidence")
  automationConfidence Int?      @map("automation_confidence")
  simulationMode       Boolean   @default(true) @map("simulation_mode")

  // Failure tracking
  failureReason        String?   @map("failure_reason")
  failureDetails       String?   @map("failure_details") @db.Text
  retryCount           Int       @default(0) @map("retry_count")
  maxRetries           Int       @default(3) @map("max_retries")

  // Browser session metadata (viewport, userAgent, etc.)
  browserSessionId     String?   @map("browser_session_id")
  browserMetadata      Json?     @map("browser_metadata")

  // Workflow state
  currentStep          String?   @map("current_step")
  stepsCompleted       Int       @default(0) @map("steps_completed")
  stepsTotal           Int?      @map("steps_total")

  // Which worker instance is handling this
  workerId             String?   @map("worker_id")

  // Timestamps
  startedAt            DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  executionLogs ExecutionLog[]
  interventions InterventionRequest[]

  @@index([userId, status])
  @@index([jobId])
  @@index([status, createdAt])   // Used by worker queue polling
  @@index([createdAt(sort: Desc)])
  @@map("auto_apply_sessions")
}

model ExecutionLog {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  timestamp      DateTime @default(now()) @db.Timestamptz(6)
  level          String   // 'info' | 'warn' | 'error' | 'debug'
  step           String   // Standardized step key e.g. 'browser_launched'
  message        String
  metadata       Json?    // Non-PII structured data
  durationMs     Int?     @map("duration_ms")
  screenshotPath String?  @map("screenshot_path")

  session AutoApplySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("execution_logs")
}

model InterventionRequest {
  id            String    @id @default(uuid()) @db.Uuid
  sessionId     String    @map("session_id") @db.Uuid
  userId        String    @map("user_id")
  jobId         String    @map("job_id") @db.Uuid
  reason        String    // InterventionReason enum value
  description   String
  screenshotUrl String?   @map("screenshot_url")
  pageUrl       String?   @map("page_url")
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolution    String?   // 'completed' | 'skipped' | 'cancelled'
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  session AutoApplySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resolvedAt])
  @@index([sessionId])
  @@map("intervention_requests")
}

model ATSPlatformProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  platform            String   @unique  // ATSPlatform enum value
  displayName         String   @map("display_name")
  automationSupported Boolean  @default(false) @map("automation_supported")
  detectionSignatures Json     @default("{}") @map("detection_signatures")
  successRate         Float    @default(0) @map("success_rate")    // Rolling average
  totalAttempts       Int      @default(0) @map("total_attempts")
  totalSuccesses      Int      @default(0) @map("total_successes")
  notes               String?
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("ats_platform_profiles")
}
